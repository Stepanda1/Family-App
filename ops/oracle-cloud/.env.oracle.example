# Public API port on the VM
PORT=4000

# PostgreSQL
POSTGRES_DB=family_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/family_app?schema=public

# Auth / JWT
JWT_ACCESS_SECRET=change-me-long-random-string
JWT_ISSUER=family-app-api
JWT_AUDIENCE=family-app-mobile
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
AUTH_REQUIRED=false

# OAuth
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# MFA
MFA_ENCRYPTION_KEY=
MFA_ISSUER=Family App
MFA_RETURN_SECRET=false

# Background workers
WORKER_POLL_MS=1000
WORKER_LEASE_MS=60000
WORKER_BATCH_SIZE=10
CRON_INTERVAL_MS=60000
CRON_BATCH_SIZE=50
