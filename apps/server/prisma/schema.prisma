generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FamilyRole {
  PARENT
  CHILD
}

enum FamilyAccessRole {
  OWNER
  PARENT
  CHILD
  GUEST
}

enum AppLanguage {
  ru
  en
}

enum AccountProvider {
  GOOGLE
  APPLE
  TELEGRAM
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

enum AuthChallengeType {
  MFA_LOGIN
}

enum ExecutorKind {
  FAMILY_MEMBER
  EXTERNAL_HELPER
}

enum PlannerItemType {
  TASK
  EVENT
  SHOPPING
}

enum PlannerPriority {
  LOW
  MEDIUM
  HIGH
}

enum PlannerStatus {
  NEW
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ExecutionStatus {
  SUCCESS
  LATE
  SKIPPED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  DONE
  DEAD
}

enum EmailDeliveryStatus {
  SENT
  FAILED
}

enum ApiIdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model Family {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @db.VarChar(120)
  timezone    String        @default("Asia/Yekaterinburg") @db.VarChar(80)
  inviteCode  String        @unique @db.VarChar(12)
  appLanguage AppLanguage   @default(ru)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  participants Participant[]
  memberships FamilyMembership[]
  executors   Executor[]
  categories  Category[]
  accountConnections AccountConnection[]
  tasks       Task[]
  auditEvents AuditEvent[]  @relation("AuditFamily")

  @@map("families")
}

model Participant {
  id           String          @id @default(uuid()) @db.Uuid
  familyId     String          @db.Uuid
  displayName  String          @db.VarChar(80)
  role         FamilyRole
  color        String          @db.VarChar(7)
  phone        String?         @db.VarChar(20)
  birthDate    DateTime?       @db.Date
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  family       Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  membership   FamilyMembership?
  createdTasks Task[]          @relation("CreatedTasks")
  executions   TaskExecution[]
  executor     Executor?

  @@index([familyId])
  @@unique([familyId, displayName])
  @@map("participants")
}

model FamilyMembership {
  id            String           @id @default(uuid()) @db.Uuid
  familyId      String           @db.Uuid
  userId        String           @db.Uuid
  role          FamilyAccessRole
  participantId String?          @unique @db.Uuid
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  family        Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  participant   Participant?     @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@unique([familyId, userId])
  @@index([userId])
  @@index([familyId])
  @@map("family_memberships")
}

model Executor {
  id          String         @id @default(uuid()) @db.Uuid
  familyId    String         @db.Uuid
  participantId String?      @unique @db.Uuid
  displayName String         @db.VarChar(80)
  kind        ExecutorKind
  contactInfo String?        @db.VarChar(120)
  createdAt   DateTime       @default(now())
  family      Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  participant Participant?   @relation(fields: [participantId], references: [id], onDelete: SetNull)
  assignments Assignment[]

  @@index([familyId])
  @@map("executors")
}

model Category {
  id         String          @id @default(uuid()) @db.Uuid
  familyId   String          @db.Uuid
  name       String          @db.VarChar(80)
  itemType   PlannerItemType
  color      String          @db.VarChar(7)
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  family     Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  tasks      Task[]

  @@unique([familyId, itemType, name])
  @@index([familyId, itemType])
  @@map("categories")
}

model Task {
  id                   String           @id @default(uuid()) @db.Uuid
  familyId             String           @db.Uuid
  creatorParticipantId String           @db.Uuid
  categoryId           String           @db.Uuid
  title                String           @db.VarChar(140)
  description          String?
  itemType             PlannerItemType
  priority             PlannerPriority  @default(MEDIUM)
  status               PlannerStatus    @default(NEW)
  listName             String?          @db.VarChar(80)
  location             String?          @db.VarChar(140)
  scheduledStartAt     DateTime?
  dueAt                DateTime?
  reminderAt           DateTime?
  reminderSentAt       DateTime?
  completedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  family               Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  creator              Participant      @relation("CreatedTasks", fields: [creatorParticipantId], references: [id], onDelete: Restrict)
  category             Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  assignments          Assignment[]
  executions           TaskExecution[]
  searchDocument       TaskSearchDocument?

  @@index([familyId, itemType, scheduledStartAt])
  @@index([familyId, status, dueAt])
  @@map("tasks")
}

model TaskSearchDocument {
  id                String          @id @default(uuid()) @db.Uuid
  familyId          String          @db.Uuid
  taskId            String          @unique @db.Uuid
  itemType          PlannerItemType
  status            PlannerStatus
  priority          PlannerPriority
  title             String          @db.VarChar(140)
  description       String?
  categoryName      String?         @db.VarChar(80)
  listName          String?         @db.VarChar(80)
  location          String?         @db.VarChar(140)
  executorNamesText String?
  contentPlain      String
  searchVector      Unsupported("tsvector")?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  task              Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([familyId, updatedAt])
  @@index([familyId, itemType, status])
  @@map("task_search_documents")
}

model Assignment {
  taskId       String   @db.Uuid
  executorId   String   @db.Uuid
  assignedAt   DateTime @default(now())
  startAt      DateTime?
  dueAt        DateTime?
  reminderOffsetMinutes Int?
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  executor     Executor @relation(fields: [executorId], references: [id], onDelete: Cascade)

  @@id([taskId, executorId])
  @@index([executorId])
  @@map("assignments")
}

model TaskExecution {
  participantId          String          @db.Uuid
  taskId                 String          @db.Uuid
  executedAt             DateTime        @default(now())
  actualDurationMinutes  Int?
  status                 ExecutionStatus
  note                   String?
  participant            Participant     @relation(fields: [participantId], references: [id], onDelete: Cascade)
  task                   Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([participantId, taskId, executedAt])
  @@index([taskId, executedAt])
  @@map("task_executions")
}

model AccountConnection {
  id           String          @id @default(uuid()) @db.Uuid
  familyId     String          @db.Uuid
  provider     AccountProvider
  accountEmail String          @db.VarChar(140)
  displayName  String          @db.VarChar(80)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  family       Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@unique([familyId, provider, accountEmail])
  @@map("account_connections")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique @db.VarChar(254)
  displayName   String?        @db.VarChar(80)
  passwordHash  String?
  mfaEnabled    Boolean        @default(false)
  mfaSecretEnc  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  oauthAccounts OAuthAccount[]
  sessions      UserSession[]
  challenges    AuthChallenge[]
  memberships   FamilyMembership[]
  auditEvents   AuditEvent[]   @relation("AuditActor")

  @@map("users")
}

model OAuthAccount {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @db.Uuid
  provider        OAuthProvider
  providerSubject String        @db.VarChar(200)
  accountEmail    String        @db.VarChar(254)
  displayName     String?       @db.VarChar(80)
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("oauth_accounts")
}

model UserSession {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @db.Uuid
  userAgent            String?
  ipAddress            String?  @db.VarChar(45)
  mfaVerified          Boolean  @default(false)
  refreshTokenHash     String   @db.Char(64)
  refreshTokenCreatedAt DateTime @default(now())
  refreshTokenRotatedAt DateTime?
  refreshTokenExpiresAt DateTime
  lastSeenAt           DateTime?
  revokedAt            DateTime?
  revokeReason         String?  @db.VarChar(80)
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
  @@map("user_sessions")
}

model AuthChallenge {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @db.Uuid
  type       AuthChallengeType
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int               @default(0)
  metadata   Json?
  createdAt  DateTime          @default(now())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("auth_challenges")
}

model AuditEvent {
  id              String           @id @default(uuid()) @db.Uuid
  familyId         String?          @db.Uuid
  actorUserId      String?          @db.Uuid
  actorSessionId   String?          @db.Uuid
  actorFamilyRole  FamilyAccessRole?
  actorEmail       String?          @db.VarChar(254)
  actorDisplayName String?          @db.VarChar(80)
  action           String           @db.VarChar(80)
  entityType       String           @db.VarChar(80)
  entityId         String?          @db.VarChar(100)
  diff             Json?
  ipAddress        String?          @db.VarChar(45)
  userAgent        String?
  correlationId    String?          @db.VarChar(64)
  traceId          String?          @db.VarChar(32)
  spanId           String?          @db.VarChar(16)
  metadata         Json?
  createdAt        DateTime         @default(now())

  family           Family?          @relation("AuditFamily", fields: [familyId], references: [id], onDelete: SetNull)
  actor            User?            @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([familyId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([correlationId])
  @@index([traceId])
  @@index([actorSessionId, createdAt])
  @@map("audit_events")
}

model OutboxEvent {
  id          String       @id @default(uuid()) @db.Uuid
  familyId    String?      @db.Uuid
  type        String       @db.VarChar(120)
  payload     Json
  status      OutboxStatus @default(PENDING)
  availableAt DateTime     @default(now())
  lockedAt    DateTime?
  lockedBy    String?      @db.VarChar(80)
  attempts    Int          @default(0)
  maxAttempts Int          @default(20)
  lastError   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  processedAt DateTime?
  deadAt      DateTime?

  emailDeliveries EmailDelivery[]

  @@index([status, availableAt])
  @@index([familyId, createdAt])
  @@map("outbox_events")
}

model EmailDelivery {
  id           String             @id @default(uuid()) @db.Uuid
  outboxEventId String            @db.Uuid
  toEmail      String             @db.VarChar(254)
  subject      String             @db.VarChar(140)
  body         String
  status       EmailDeliveryStatus @default(SENT)
  createdAt    DateTime           @default(now())

  outboxEvent  OutboxEvent        @relation(fields: [outboxEventId], references: [id], onDelete: Cascade)

  @@unique([outboxEventId, toEmail])
  @@index([toEmail, createdAt])
  @@map("email_deliveries")
}

model ApiIdempotencyKey {
  id                 String               @id @default(uuid()) @db.Uuid
  idempotencyKey     String               @db.VarChar(255)
  operation          String               @db.VarChar(120)
  subject            String               @db.VarChar(255)
  requestHash        String               @db.Char(64)
  status             ApiIdempotencyStatus @default(PROCESSING)
  responseStatusCode Int?
  responseHeaders    Json?
  responseBody       Json?
  errorMessage       String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  expiresAt          DateTime

  @@unique([idempotencyKey, operation, subject])
  @@index([expiresAt])
  @@index([status, createdAt])
  @@map("api_idempotency_keys")
}
