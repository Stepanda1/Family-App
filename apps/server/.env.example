DATABASE_URL="postgresql://postgres:1410197140qzps@localhost:5432/family_app?schema=public"
PORT=4000

# Auth / JWT
# Use a long random string in production. Example (PowerShell):
#   [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Max 256 }))
JWT_ACCESS_SECRET="change-me"
JWT_ISSUER="family-app-api"
JWT_AUDIENCE="family-app-mobile"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# Optional: enforce JWT for all non-auth endpoints
AUTH_REQUIRED=false

# OAuth (mobile sends idToken)
GOOGLE_CLIENT_ID=""
APPLE_CLIENT_ID=""

# MFA (TOTP)
# 32 bytes base64 (AES-256-GCM key). Example:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 }))
MFA_ENCRYPTION_KEY=""
MFA_ISSUER="Family App"
MFA_RETURN_SECRET=false

# Background workers (Outbox + Cron)
WORKER_POLL_MS=1000
WORKER_LEASE_MS=60000
WORKER_BATCH_SIZE=10
CRON_INTERVAL_MS=60000
CRON_BATCH_SIZE=50
